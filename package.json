{
  "name": "webnovel-writer-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "test": "node --test tests/**/*.test.mjs",
    "test:e2e": "node ./scripts/run-playwright-e2e.mjs",
    "test:e2e:headed": "node ./scripts/run-playwright-e2e.mjs --headed",
    "test:e2e:live-ai": "node ./scripts/run-playwright-e2e.mjs tests/e2e/live-ai.spec.mjs"
  },
  "dependencies": {
    "next": "^16.1.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.9.3"
  }
}
